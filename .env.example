# ============================================================================
# Application Configuration
# ============================================================================

# Environment Mode
NODE_ENV=development

# ============================================================================
# Logging Configuration
# ============================================================================

# Log Level: error, warn, info, debug (default: info)
LOG_LEVEL=info

# ============================================================================
# Prisma AIRS API Configuration (Optional)
# ============================================================================

PRISMA_AIRS_TSG_ID=your_tsg_id_here
PRISMA_AIRS_APP_ID=your_customer_app_id_here
PRISMA_AIRS_APP_NAME=your_litellm_app_name_here

# ============================================================================
# Litellm Configuration
# Can be used as a lightweight proxy to access various LLM providers
# Can't be used simultaneously with other LLM providers
# ============================================================================
# LITELLM_BASE_URL=http://localhost:8080
# LITELLM_API_KEY=sk-your_litellm_api_key_here

# Optional guardrail configuration in LiteLLM. Comma-separated list of guardrail
# names. If set, the coordinator will pass them to LiteLLM which will enforce on all LLM calls.
# LITELLM_GUARDRAIL_NAME=PANW-pre,PANW-post

# Default LLM model (must match a model ID in LiteLLM)
# Falls back to first available LiteLLM model if not found
# LITELLM_DEFAULT_MODEL=qwen.qwen3-32b-v1:0

# COMPOSE_PROJECT_NAME=hr-it-bot-v2